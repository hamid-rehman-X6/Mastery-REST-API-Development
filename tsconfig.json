{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "compilerOptions": {
        "target": "es6",
        "module": "commonjs",
        "rootDir": "src",
        "baseUrl": "./",
        "ignoreDeprecations": "6.0",
        "outDir": "dist",
        "removeComments": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "paths": {
            "@/*" : [
                "src/*"
            ]
        },
        "typeRoots": ["./src/@types"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules"]
}